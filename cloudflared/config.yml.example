# ================================================================
#  cloudflared/config.yml.example
#  Template for Cloudflare Tunnel ingress config.
#
#  To create manually:
#    1. Copy this file to cloudflared/config.yml
#    2. Fill in TUNNEL_ID (from: cloudflared tunnel list)
#    3. Update hostnames to match your .env / DNS plan
#    4. Remove any entries for services you keep disabled
#    5. Add matching DNS records in Cloudflare dashboard
# ================================================================

# Get from: cloudflared tunnel list  OR  Cloudflare Zero Trust dashboard
tunnel: <YOUR-TUNNEL-ID>
credentials-file: /etc/cloudflared/credentials.json

ingress:
  # ── Main application ────────────────────────────────────────────
  # Default .env example uses: main.${DOMAIN}
  - hostname: main.example.com
    service: http://caddy:80

  # ── Dozzle: real-time log viewer ───────────────────────────────
  # Enabled when ENABLE_DOZZLE=true
  - hostname: dozzle.example.com
    service: http://caddy:80

  # ── Filebrowser: log file manager ─────────────────────────────
  # Enabled when ENABLE_FILEBROWSER=true
  - hostname: files.example.com
    service: http://caddy:80

  # ── Deploy Code: optional self-deploy UI/API ───────────────────
  # Enabled when DOCKER_DEPLOY_CODE_ENABLED=true
  - hostname: deploy.example.com
    service: http://caddy:80

  # ── WebSSH: browser terminal ──────────────────────────────────
  # Enabled when ENABLE_WEBSSH=true
  # ⚠️  Protect with Cloudflare Access or Tailscale for production!
  - hostname: ttyd.example.com
    service: http://caddy:80

  # ── Tinyauth: authentication portal ────────────────────────────
  # Always required when using Tinyauth forward_auth
  - hostname: auth.example.com
    service: http://caddy:80

  # ── Wildcard: dynamic Repo Agent ttyd slots ────────────────────
  # Khi user bấm Launch trên Repo Agent UI, manager spawn container
  # ttyd với label caddy=http://ttydNNN.${DOMAIN}. Wildcard ingress
  # này forward MỌI subdomain chưa khớp các rule ở trên về Caddy
  # → Caddy phân giải tiếp theo container label.
  #
  # YÊU CẦU DNS (làm 1 lần trên Cloudflare dashboard):
  #   *.example.com   CNAME   <tunnel-id>.cfargotunnel.com  (proxied=true)
  #
  # Dùng `node scripts/cloudflare-cname-bulk.js create-wildcard` để tạo
  # tự động (đọc CLOUDFLARED_API_TOKEN + ZONE_ID từ .env).
  - hostname: "*.example.com"
    service: http://caddy:80

  # ── Catch-all: return 404 for any unlisted hostnames ──────────
  - service: http_status:404
